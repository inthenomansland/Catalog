# Copy this file to .env and fill in your values before deploying.
# Never commit the real .env file to git.

# Admin password for the catalogue admin panel
ADMIN_PASSWORD=change-me-to-something-strong

# Random secret used to sign login tokens — make it long and random
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
