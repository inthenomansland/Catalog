# Copy this file to .env and fill in your values before deploying.
# Never commit the real .env file to git.

# Admin password for the catalogue admin panel
ADMIN_PASSWORD=change-me-to-something-strong

# Random secret used to sign login tokens — make it long and random
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Email notifications for Known Issue submissions (optional)
# Use a personal Gmail or Outlook.com account with an app password.
# If these are left blank, notifications are simply skipped.
#
# Gmail:       SMTP_HOST=smtp.gmail.com
# Outlook.com: SMTP_HOST=smtp-mail.outlook.com
#
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-personal-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
